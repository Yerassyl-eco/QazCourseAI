# ─────────────────────────────────────────────────────────────
# QazCourse AI — Example environment file
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so your real keys never end up on GitHub.
# ─────────────────────────────────────────────────────────────

# --- Lovable Cloud / Supabase (managed automatically on Lovable) ---
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
SUPABASE_PROJECT_ID="your-project-id"

# Same values, exposed to the browser via Vite
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# --- Server-only secrets (NEVER expose to the client / NEVER prefix with VITE_) ---
# Service role key — bypasses RLS. Server functions only.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Lovable AI Gateway — used by the 40-question AI matching engine
LOVABLE_API_KEY="your-lovable-api-key"

# --- Optional third-party providers (add only what you use) ---
# GOOGLE_OAUTH_CLIENT_ID=""
# GOOGLE_OAUTH_CLIENT_SECRET=""
# RESEND_API_KEY=""
